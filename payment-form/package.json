    "react-redux": "^9.2.0",
    "uuid": "^13.0.0",
    "web-vitals": "^4.2.4",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@emotion/jest": "^11.13.0",
    "@eslint/js": "^9.36.0",
    "@testing-library/jest-dom": "^6.6.3",
